# 应用侧可调参数（歌手名、新歌页、定时任务等）
# 用法：复制为项目根目录下的 `.env.qqmc`，按需修改；与 `.env` 可同时存在（后加载的键会覆盖先加载的同名键）。
# 亦可把下列变量直接写进 `.env`，效果相同。

# ---------- 新歌页（与 web_service/constants 一致）----------
QQMC_NEW_SONG_ARTIST=李宇春
QQMC_NEW_SONG_NAME=春雨里
QQMC_NEW_SONG_CHART_START_DATE=2026-03-16
QQMC_NEW_SONG_CHART_NUM_POINTS=10

# ---------- 定时任务（与 schedulers 一致）----------
QQMC_TOPLIST_ARTIST_NAME=李宇春
QQMC_TOPLIST_SCHEDULE_START_HOUR=8
QQMC_TOPLIST_INTERVAL_MINUTES=20
QQMC_NEW_SONG_UPDATE_INTERVAL_SEC=60
QQMC_CRAWL_TRACK_ARTIST_NAME=李宇春
QQMC_CRAWL_TRACK_INTERVAL_MINUTES=30

# ---------- 首页默认（歌曲 TOP N 隐藏域等）----------
# 不设置时与 QQMC_TOPLIST_ARTIST_NAME 相同
# QQMC_DEFAULT_TOPSONGS_ARTIST_NAME=李宇春
