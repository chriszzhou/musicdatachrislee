# 业务侧可调参数（歌手名、新歌名、定时间隔等）建议放在单独文件：
#   cp .env.qqmc.example .env.qqmc
# 与 `.env` 可同时使用；加载顺序为先 `.env` 再 `.env.qqmc`（后者覆盖同名键）。

# Base API
QQMUSIC_BASE_URL=https://u.y.qq.com/cgi-bin/musicu.fcg
NETEASE_BASE_URL=https://music.163.com
KUGOU_BASE_URL=http://mobilecdn.kugou.com

# Request behavior
QQMUSIC_TIMEOUT=15
QQMUSIC_MAX_RETRIES=3
QQMUSIC_RATE_LIMIT_QPS=1.0
NETEASE_RATE_LIMIT_QPS=8.0
NETEASE_METRIC_WORKERS=8
NETEASE_METRIC_BATCH_SIZE=10
KUGOU_RATE_LIMIT_QPS=5.0
KUGOU_METRIC_WORKERS=8
KUGOU_METRIC_BATCH_SIZE=10

# Crawl options
QQMUSIC_DEFAULT_ARTIST_PAGE_SIZE=40
QQMUSIC_DEFAULT_SONG_PAGE_SIZE=50

# （QQMC_* 业务变量已集中到 `.env.qqmc.example`，可复制为 `.env.qqmc`）

# SQLite（原生连接与 SQLAlchemy 快照库均会应用长等待 + WAL）
# QQMC_SQLITE_CONNECT_TIMEOUT=30
# QQMC_SQLITE_BUSY_TIMEOUT_MS=60000
